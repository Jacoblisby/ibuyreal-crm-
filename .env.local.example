# iBuyReal CRM — environment variables
# Copy to .env.local and fill in values.
# .env.local is in .gitignore and is never committed.

# ─── Database ───────────────────────────────────────────────────────────────
# Source the full connection string from AWS Secrets Manager (IBUYREAL_DB).
# The app targets the `crm` schema — search_path is set automatically in client.ts.
#
# Format: postgres://user:pass@host:5432/dbname
# Run `npm run env:pull` to fetch credentials automatically from AWS Secrets Manager.
# Requires `aws configure` (or AWS_PROFILE env var) to be set up first.
#
IBUYREAL_DB=

# ─── App URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Prod: https://<your-app-runner-or-alb-domain>

# ─── iBuyReal AVM (API Gateway → Lambda) ────────────────────────────────────
# Leave empty for local dev — app falls back to using listPrice as FMV.
# Set when the Lambda endpoint is provisioned.
AVM_URL=
AVM_API_KEY=

