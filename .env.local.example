# iBuyReal CRM — environment variables
# Kopier til .env.local og udfyld.

# ─── Database ───────────────────────────────────────────────────────────────
# Lokal dev (Homebrew Postgres uden password):
DATABASE_URL=postgres://jacoblisby@localhost:5432/ibuyreal_crm
# Coolify prod: postgres://postgres:<pass>@ibuyreal-db:5432/postgres

# ─── App URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Prod: https://app.ibrc.dk

# ─── iBuyReal AVM (XGBoost på AWS) ─────────────────────────────────────────
# Tom = brug listPrice som FMV-fallback (ingen alpha-signal).
# Sæt når API'en er klar.
AVM_URL=
AVM_API_KEY=
